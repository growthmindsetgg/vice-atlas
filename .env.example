# Public — exposed in the client bundle. MUST start with NEXT_PUBLIC_.
# The fully-qualified origin of the deployed site. Used for canonical URLs,
# OpenGraph image absolute URLs, sitemap, robots, and JSON-LD. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://viceatlas.gg

# Server-only — never prefix these with NEXT_PUBLIC_.
# Beehiiv API credentials for /api/subscribe. If either is missing, the
# subscribe route logs the email and returns ok:true (soft-fail) — useful for
# preview deploys, but real subscriptions won't be created.
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=
